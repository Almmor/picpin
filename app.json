{
    "name": "PicPin",
    "version": "1.0.0",

    "window": {
        "defaultWidth": 340,
        "defaultHeight": 340,
        "minWidth": 200,
        "minHeight": 200,
        "background": "rgba(255, 255, 255, 0.95)",
        "borderRadius": 10,
        "hideControls": true
    },

    "viewer": {
        "mode": "slide",
        "autoPlay": true,
        "intervalMs": 3000,
        "imageFit": "contain",
        "gridItemSize": 70,
        "gridGap": 8
    },

    "theme": {
        "primaryColor": "#ff79c6",
        "secondaryColor": "#fee101",
        "backgroundColor": "#ffffff",
        "textColor": "#424242",
        "accentColor": "#ff4081"
    },

    "tray": {
        "tooltip": "PicPin 📌",
        "menu": [
            { "label": "显示/隐藏", "action": "toggle" },
            { "label": "---------" },
            { "label": "📌 置顶窗口", "action": "pin" },
            { "label": "⏸ 播放/暂停", "action": "play" },
            { "label": "🔲 网格视图", "action": "grid" },
            { "label": "---------" },
            { "label": "📂 打开图片目录", "action": "openFolder" },
            { "label": "---------" },
            { "label": "❌ 退出", "action": "quit" }
        ]
    },

    "images": []
}
